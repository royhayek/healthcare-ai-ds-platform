# ──────────────────────────────────────────────────────────────────────────────
# Root environment template (convenience copy of the backend variables).
#
# NOTE: this file is NOT auto-loaded. The app reads backend/.env via an absolute
# path in backend/core/config.py, and docker-compose.yml sets its own values.
# Keep this only if you run tooling from the repo root that expects a root .env;
# otherwise prefer backend/.env.example as the single source of truth.
# Copy to .env and fill in real values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local Postgres via docker-compose (host port 5433 → container 5432).
DATABASE_URL=postgresql+asyncpg://aids:aids@localhost:5433/aids

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Redis via docker-compose (host port 6380 → container 6379).
REDIS_URL=redis://localhost:6380/0

# ── File storage ──────────────────────────────────────────────────────────────
STORAGE_ROOT=./data

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins.
CORS_ORIGINS=["http://localhost:3001"]

# ── Auth ──────────────────────────────────────────────────────────────────────
# DEV_MODE=true → trusts the X-User-Id header instead of verifying a Supabase JWT.
DEV_MODE=true

# ── the model API ────────────────────────────────────────────────────────────────
# Per project rule 6: pinned model strings only, never aliases.
ANTHROPIC_API_KEY=sk-ant-...
