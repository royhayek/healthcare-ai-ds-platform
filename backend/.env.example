# ──────────────────────────────────────────────────────────────────────────────
# Backend (FastAPI + Celery) environment template.
# Copy to backend/.env and fill in real values:  cp .env.example .env
# Keys here mirror backend/core/config.py (Settings) 1:1.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local Postgres via docker-compose (default). Swap to the Supabase connection
# string when wiring production auth. See backend/core/database.py.
DATABASE_URL=postgresql+asyncpg://aids:aids@localhost:5432/aids

# ── Redis ─────────────────────────────────────────────────────────────────────
# Celery broker / result backend and progress-event pub-sub.
REDIS_URL=redis://localhost:6379/0

# ── File storage ──────────────────────────────────────────────────────────────
# Local filesystem root for datasets + deliverables (swappable to Supabase
# Storage - see backend/core/storage.py).
STORAGE_ROOT=./data

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins.
CORS_ORIGINS=["http://localhost:3000"]

# ── Supabase (optional in dev) ────────────────────────────────────────────────
# Only needed when DEV_MODE=false (real auth) or when using Supabase Storage.
# config.py defaults keep these blank; uncomment and fill to enable.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=datasets

# ── Auth ──────────────────────────────────────────────────────────────────────
# DEV_MODE=true → trusts the X-User-Id header instead of verifying a Supabase JWT.
# Set to false and provide SUPABASE_JWT_SECRET when deploying.
DEV_MODE=true
SUPABASE_JWT_SECRET=

# ── the model API ────────────────────────────────────────────────────────────────
# Per project rule 6: never use aliases like claude-sonnet-latest. The exact
# model strings below are what the reproducibility manifest records - changing
# them requires a note in DECISIONS.md.
ANTHROPIC_API_KEY=sk-ant-...

CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_OPUS_MODEL=claude-opus-4-7
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
